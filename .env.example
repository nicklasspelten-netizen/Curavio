# Curavio – Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte aus

# Server
PORT=3000

# JWT Secret – beliebiger langer zufälliger String
JWT_SECRET=curavio_super_secret_key_bitte_aendern_2024

# Anthropic API Key – von https://console.anthropic.com (KI-Berichte + KI-Disposition)
ANTHROPIC_API_KEY=sk-ant-...

# DSGVO: AES-256-Schluessel fuer Feld-Verschluesselung (IBAN, Telefon, Versichertennr.)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WICHTIG: Auch auf Render als Env-Variable setzen! Ohne Key wird ein
# Fallback aus JWT_SECRET abgeleitet (funktioniert, aber dedizierter Key ist besser).
ENCRYPTION_KEY=

# OpenRouteService fuer Geocoding + Routenplanung (kostenlos: openrouteservice.org)
# Ohne Key: Geocoding via OSM Nominatim, Fahrzeiten per Luftlinien-Schaetzung
ORS_API_KEY=

# E-Mail-Versand (SMTP). Alternativ im Admin unter Einstellungen pflegbar.
# ENV hat Vorrang. Beispiel Gmail: Host smtp.gmail.com, Port 587, App-Passwort als SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Curavio <info@curavio.de>

# Oeffentliche App-URL fuer Links in E-Mails
APP_URL=https://curavio.onrender.com

# Optionale E-Mail-Benachrichtigungen (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=info@curavio.de
# SMTP_PASS=...
